# ─────────────────────────────────────────────
#  ScraperBot – Environment Configuration
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Telegram ──────────────────────────────────
# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal or group chat ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Lazada Account ────────────────────────────
LAZADA_EMAIL=your_lazada_email@example.com
LAZADA_PASSWORD=your_lazada_password

# ── Lazada Country ────────────────────────────
# Options: sg (Singapore), my (Malaysia), ph (Philippines),
#          id (Indonesia), th (Thailand), vn (Vietnam)
LAZADA_COUNTRY=sg

# ── Search Configuration ──────────────────────
# Comma-separated list of search queries to run
SEARCH_QUERIES=laptop,headphones

# Minimum price filter (leave blank to disable)
MIN_PRICE=

# Maximum price filter (leave blank to disable)
MAX_PRICE=500

# Sort order: price_asc | price_desc | popularity | newest | rating
SORT_BY=price_asc

# Maximum number of items to add to cart per search query
MAX_ITEMS_PER_QUERY=3

# ── Scheduler ─────────────────────────────────
# How often to run the scraper (in minutes)
CHECK_INTERVAL_MINUTES=60

# ── Browser ───────────────────────────────────
# Run browser in headless mode (true/false)
HEADLESS=true

# Seconds to wait between page actions (helps avoid detection)
ACTION_DELAY_SECONDS=2
